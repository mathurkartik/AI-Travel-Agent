# LLM Provider (groq, openai, anthropic)
LLM_PROVIDER=groq

# Groq Configuration (Primary - 100k tokens/day limit)
GROQ_API_KEY=gsk_...
GROQ_MODEL=mixtral-8x7b-32768
GROQ_MAX_TOKENS_PER_REQUEST=4000
GROQ_TEMPERATURE=0.1

# Token Budget Management (Groq = 100k tokens/day)
ENABLE_TOKEN_TRACKING=true
MAX_TOKENS_PER_PLAN_REQUEST=15000
TOKEN_BUFFER_PERCENT=20

# Fallback: OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview

# Fallback: Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Phase Status (for development)
# Current Phase: 6 (Review Agent)
# Next Phase: 7 (Repair Loop)
ENABLE_REVIEW_AGENT=true   # Phase 6 complete
ENABLE_REPAIR_LOOP=false   # Set to true after Phase 7 implementation

# Agent Settings
AGENT_TIMEOUT_SECONDS=30
MAX_REVIEW_RETRIES=3

# Caching (reduces token usage)
ENABLE_RESPONSE_CACHE=true
CACHE_TTL_SECONDS=3600

# Tool Router Settings (stubs for now)
ENABLE_WEB_SEARCH=false
ENABLE_GEO_ROUTING=false
ENABLE_PRICING_API=false
ENABLE_FX_API=false
